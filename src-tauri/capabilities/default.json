{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"os:default",
		"os:allow-hostname",
		"os:allow-os-type",
		"os:allow-platform",
		"core:window:allow-start-dragging",
		"fs:default",
		"dialog:default",
		"shell:default",
		"fs:allow-write-file",
		{
			"identifier": "opener:allow-open-path",
			"allow": [
				{
					"path": "**"
				}
			]
		}
	]
}
